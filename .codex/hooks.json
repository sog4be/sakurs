{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.claude/hooks/validate-commit-msg.sh\"",
            "statusMessage": "Validating commit message"
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.claude/hooks/block-main-push.sh\"",
            "statusMessage": "Checking push target"
          },
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/.claude/hooks/validate-pr.sh\"",
            "statusMessage": "Validating pull request"
          }
        ]
      }
    ]
  }
}
